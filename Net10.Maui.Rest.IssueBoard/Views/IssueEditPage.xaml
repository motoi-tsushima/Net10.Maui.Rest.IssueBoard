<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Net10.Maui.Rest.IssueBoard.Views.IssueEditPage"
             Title="課題内容編集">
    
    <Grid RowDefinitions="*,Auto" Padding="10">
        
        <!-- 編集エリア（スクロール可能） -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="10">
                
                <Grid ColumnDefinitions="120,*">
                    <Label Grid.Column="0" Text="記入者氏名:" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="AuthorNameLabel" VerticalOptions="Center"/>
                </Grid>

                <Grid ColumnDefinitions="120,*">
                    <Label Grid.Column="0" Text="登録日時:" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="CreatedAtLabel" VerticalOptions="Center"/>
                </Grid>

                <Grid ColumnDefinitions="120,*">
                    <Label Grid.Column="0" Text="カテゴリ名:" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Entry Grid.Column="1" x:Name="CategoryEntry" Placeholder="カテゴリを入力（任意）" MaxLength="30"/>
                </Grid>

                <Label Text="課題タイトル:" FontAttributes="Bold"/>
                <Entry x:Name="TitleEntry" Placeholder="課題タイトルを入力" MaxLength="100"/>
                <Label x:Name="TitleErrorLabel" TextColor="Red" IsVisible="False"/>

                <Label Text="課題の文面:" FontAttributes="Bold"/>
                <Editor x:Name="DescriptionEditor" 
                        Placeholder="課題の文面を入力" 
                        MinimumHeightRequest="100" 
                        MaximumHeightRequest="300"
                        AutoSize="TextChanges"
                        MaxLength="2000"/>
                <Label x:Name="DescriptionErrorLabel" TextColor="Red" IsVisible="False"/>

                <Grid ColumnDefinitions="120,*">
                    <Label Grid.Column="0" Text="現在の状況:" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Picker Grid.Column="1" x:Name="StatusPicker" VerticalOptions="Center"/>
                </Grid>

                <Label Text="解決の文面:" FontAttributes="Bold"/>
                <Editor x:Name="ResolutionEditor" 
                        Placeholder="解決の文面を入力（任意）" 
                        MinimumHeightRequest="100" 
                        MaximumHeightRequest="300"
                        AutoSize="TextChanges"
                        MaxLength="2000"/>

                <Grid ColumnDefinitions="120,*">
                    <Label Grid.Column="0" Text="解決担当者名:" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Entry Grid.Column="1" x:Name="ResolverNameEntry" Placeholder="担当者名を入力（任意）" MaxLength="50"/>
                </Grid>

                <Grid ColumnDefinitions="120,*">
                    <Label Grid.Column="0" Text="最終結果日時:" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="（更新時に自動設定）" VerticalOptions="Center"/>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ボタン -->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*,*" 
              ColumnSpacing="10"
              Margin="0,10,0,0">
            <Button Grid.Column="0" Text="更新" Clicked="OnUpdateClicked"/>
            <Button Grid.Column="1" Text="戻る" Clicked="OnBackClicked"/>
        </Grid>
    </Grid>
</ContentPage>