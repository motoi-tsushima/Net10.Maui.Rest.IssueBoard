<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Net10.Maui.Rest.IssueBoard.Views.IssueListPage"
             Title="課題一覧">
    
    <Grid RowDefinitions="Auto,*,Auto" Padding="10">
        
        <!-- 更新ボタン -->
        <Button Grid.Row="0" 
                Text="更新" 
                Clicked="OnRefreshClicked"
                Margin="0,0,0,10"
                HorizontalOptions="End"/>

        <!-- 課題一覧 with RefreshView -->
        <RefreshView Grid.Row="1" x:Name="RefreshView" Refreshing="OnRefreshViewRefreshing">
            <ScrollView>
                <CollectionView x:Name="IssuesCollectionView"
                                SelectionMode="Single"
                                SelectionChanged="OnIssueSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="5" 
                                   Padding="10" 
                                   BorderColor="LightGray"
                                   CornerRadius="5">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" 
                                      ColumnDefinitions="Auto,*">
                                    
                                    <Label Grid.Row="0" Grid.Column="0" 
                                           Text="記入者:" 
                                           FontAttributes="Bold"
                                           Margin="0,0,10,0"/>
                                    <Label Grid.Row="0" Grid.Column="1" 
                                           Text="{Binding AuthorName}"/>

                                    <Label Grid.Row="1" Grid.Column="0" 
                                           Text="登録日時:" 
                                           FontAttributes="Bold"
                                           Margin="0,5,10,0"/>
                                    <Label Grid.Row="1" Grid.Column="1" 
                                           Text="{Binding CreatedAt, StringFormat='{0:yyyy/MM/dd HH:mm}'}"
                                           Margin="0,5,0,0"/>

                                    <Label Grid.Row="2" Grid.Column="0" 
                                           Text="カテゴリ:" 
                                           FontAttributes="Bold"
                                           Margin="0,5,10,0"/>
                                    <Label Grid.Row="2" Grid.Column="1" 
                                           Text="{Binding Category}"
                                           Margin="0,5,0,0"/>

                                    <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding Title}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           Margin="0,10,0,5"
                                           TextColor="{StaticResource Primary}"/>

                                    <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                          ColumnDefinitions="Auto,*,Auto,*"
                                          Margin="0,5,0,0">
                                        <Label Grid.Column="0" 
                                               Text="状況:" 
                                               FontAttributes="Bold"
                                               Margin="0,0,10,0"/>
                                        <Label Grid.Column="1" 
                                               Text="{Binding StatusDisplay}"/>
                                        
                                        <Label Grid.Column="2" 
                                               Text="担当者:" 
                                               FontAttributes="Bold"
                                               Margin="20,0,10,0"/>
                                        <Label Grid.Column="3" 
                                               Text="{Binding ResolverName}"/>
                                    </Grid>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>
        </RefreshView>

        <!-- ローディングインジケータ -->
        <ActivityIndicator Grid.Row="1" 
                          x:Name="LoadingIndicator"
                          IsRunning="False"
                          IsVisible="False"
                          Color="{StaticResource Primary}"
                          VerticalOptions="Center"
                          HorizontalOptions="Center"/>

        <!-- ボタン -->
        <Grid Grid.Row="2" 
              ColumnDefinitions="*,*" 
              ColumnSpacing="10"
              Margin="0,10,0,0">
            <Button Grid.Column="0" 
                    Text="課題登録" 
                    Clicked="OnCreateClicked"/>
            <Button Grid.Column="1" 
                    Text="終了" 
                    Clicked="OnExitClicked"/>
        </Grid>
    </Grid>
</ContentPage>